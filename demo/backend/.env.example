# NVIDIA API key — free from https://build.nvidia.com
NVIDIA_API_KEY=nvapi-your-key-here

# Tavily API key (for web search) — free from https://tavily.com
TAVILY_API_KEY=tvly-your-key-here

# Docker socket (for sandbox mode) — Colima users:
DOCKER_HOST=unix:///Users/YOUR_USERNAME/.colima/default/docker.sock
# Docker Desktop users (usually auto-detected):
# DOCKER_HOST=unix:///var/run/docker.sock
